@model RegisterNursePageVM
@{
    ViewData["Title"] = "تسجيل ممرض";
}

<div class="container section-block" style="max-width:560px">
    <h1 class="page-title">تسجيل ممرض</h1>
    <form asp-action="RegisterNurse" method="post" enctype="multipart/form-data" class="form-stack wide" data-loading>
        @Html.AntiForgeryToken()
        <div class="field"><label asp-for="FullName"></label><input asp-for="FullName" /><span asp-validation-for="FullName"></span></div>
        <div class="field"><label asp-for="Email"></label><input asp-for="Email" /><span asp-validation-for="Email"></span></div>
        <div class="field"><label asp-for="PhoneNumber"></label><input asp-for="PhoneNumber" /></div>
        <div class="field"><label asp-for="Password"></label><input asp-for="Password" /><span asp-validation-for="Password"></span></div>
        <div class="field"><label asp-for="ConfirmPassword"></label><input asp-for="ConfirmPassword" /><span asp-validation-for="ConfirmPassword"></span></div>
        <div class="field"><label asp-for="Specialization"></label><input asp-for="Specialization" /><span asp-validation-for="Specialization"></span></div>
        <div class="field"><label asp-for="YearsOfExperience"></label><input asp-for="YearsOfExperience" /></div>
        <div class="field"><label asp-for="Bio"></label><textarea asp-for="Bio" rows="3"></textarea></div>
        <div class="field"><label asp-for="LicenseFile"></label><input asp-for="LicenseFile" type="file" accept="image/*" /></div>
        <div class="field"><label asp-for="City"></label><input asp-for="City" /></div>
        <div class="field"><label asp-for="Neighborhood"></label><input asp-for="Neighborhood" /></div>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <button type="submit" class="btn btn-primary">إرسال للمراجعة</button>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
