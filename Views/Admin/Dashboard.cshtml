@model AdminDashboardVM
@{ ViewData["Title"] = "الإدارة"; }
@section Sidebar { <partial name="_Sidebar" /> }

<div class="admin-page">
    <header class="admin-page__head">
        <h1 class="admin-page__title">لوحة الإدارة</h1>
        <p class="admin-page__lead muted">نظرة عامة على المستخدمين والعيادات والمواعيد والإيرادات.</p>
    </header>
    <div class="stat-cards admin-stat-grid">
        <div class="stat-card"><strong>@Model.TotalUsers</strong><div class="muted">مستخدمون</div></div>
        <div class="stat-card"><strong>@Model.TotalNurses</strong><div class="muted">ممرضون</div></div>
        <div class="stat-card"><strong>@Model.TotalClinics</strong><div class="muted">عيادات</div></div>
        <div class="stat-card"><strong>@Model.AppointmentsToday</strong><div class="muted">مواعيد اليوم</div></div>
        <div class="stat-card"><strong>@Model.RevenueEstimate.ToString("N0")</strong><div class="muted">إيرادات مكتملة (شهري)</div></div>
        <div class="stat-card"><strong>@Model.PendingVerifications</strong><div class="muted">بانتظار التحقق</div></div>
    </div>
    <h2 class="admin-page__title" style="font-size:1.15rem;margin-bottom:0.75rem">نشاط حديث</h2>
    <ul class="admin-activity-list">
        @foreach (var a in Model.RecentActivity)
        {
            <li>@a.Text <small class="muted">@a.At.ToLocalTime().ToString("g")</small></li>
        }
    </ul>
</div>
