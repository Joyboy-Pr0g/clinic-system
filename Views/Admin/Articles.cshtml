@model List<HomeNursingSystem.Models.Article>
@{ ViewData["Title"] = "المقالات"; }
@section Sidebar { <partial name="_Sidebar" /> }

<div class="admin-page">
    <header class="admin-page__head" style="display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:1rem">
        <div>
            <h1 class="admin-page__title" style="margin-bottom:0.35rem">المقالات والأخبار</h1>
            <p class="admin-page__lead muted" style="margin:0">إدارة المحتوى المنشور على الموقع.</p>
        </div>
        <a class="btn btn-primary" asp-action="CreateArticle">جديد</a>
    </header>
    <div class="admin-table-card">
        <div class="table-wrap">
            <table class="data-table">
                <thead><tr><th>صورة</th><th>العنوان</th><th>فئة</th><th>منشور</th><th>خبر</th><th>إجراءات</th></tr></thead>
                <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(a.ThumbnailImagePath))
                            { <img class="table-thumb" src="@a.ThumbnailImagePath" alt="" width="56" height="56" /> }
                            else { <span class="muted">—</span> }
                        </td>
                        <td>@a.Title</td>
                        <td>@a.Category</td>
                        <td>@(a.IsPublished ? "نعم" : "لا")</td>
                        <td>@(a.IsNews ? "نعم" : "لا")</td>
                        <td>
                            <div class="service-table-actions">
                                <a class="btn btn-sm btn-outline-edit" asp-action="ArticleDetails" asp-route-id="@a.ArticleId">عرض</a>
                                <a class="btn btn-sm btn-outline-edit" asp-action="EditArticle" asp-route-id="@a.ArticleId">تعديل</a>
                                <form asp-action="DeleteArticle" asp-route-id="@a.ArticleId" method="post" style="display:inline" onsubmit="return confirm('Delete this article?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
