@model List<HomeNursingSystem.Models.ContactMessage>
@{ ViewData["Title"] = "الرسائل"; }
@section Sidebar { <partial name="_Sidebar" /> }

<div class="admin-page">
    <header class="admin-page__head">
        <h1 class="admin-page__title">صندوق الرسائل</h1>
        <p class="admin-page__lead muted">رسائل التواصل من الموقع — تعليم كمقروء، الرد، أو الحذف.</p>
    </header>

    @foreach (var m in Model)
    {
        <article class="admin-contact-card">
            <p style="margin:0 0 0.35rem"><strong>@m.FullName</strong> — @m.Email · @m.PhoneNumber</p>
            <p style="margin:0 0 0.35rem"><strong>@m.Subject</strong></p>
            <p style="margin:0">@m.Message</p>
            <p class="admin-contact-card__meta muted">@m.CreatedAt.ToLocalTime().ToString("g") · @(m.IsRead ? "مقروء" : "جديد")</p>
            @if (!string.IsNullOrEmpty(m.ReplyMessage))
            {
                <p class="muted" style="margin:0.65rem 0 0"><strong>رد:</strong> @m.ReplyMessage</p>
            }
            <div class="admin-contact-actions">
                <form asp-action="MarkContactRead" asp-route-id="@m.ContactMessageId" method="post" style="margin:0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline">تعليم كمقروء</button>
                </form>
                <form asp-action="DeleteContact" asp-route-id="@m.ContactMessageId" method="post" style="margin:0" onsubmit="return confirm('Delete this message permanently?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                </form>
            </div>
            <form asp-action="ReplyContact" asp-route-id="@m.ContactMessageId" method="post" class="form-stack" style="margin-top:0.85rem;max-width:100%">
                @Html.AntiForgeryToken()
                <textarea name="replyMessage" rows="2" placeholder="نص الرد (يُحفظ في النظام)"></textarea>
                <button type="submit" class="btn btn-sm btn-primary">حفظ الرد</button>
            </form>
        </article>
    }
</div>
