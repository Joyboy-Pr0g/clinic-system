@model List<HomeNursingSystem.Models.Clinic>
@{ ViewData["Title"] = "العيادات"; }
@section Sidebar { <partial name="_Sidebar" /> }

<div class="admin-page">
    <header class="admin-page__head">
        <h1 class="admin-page__title">العيادات</h1>
        <p class="admin-page__lead muted">راجع بيانات العيادة العامة أو الوثيقة ثم قبول أو رفض أو تعليق. الحذف النهائي يزيل العيادة وجميع الحجوزات والخدمات المرتبطة (دون حذف حساب المالك).</p>
    </header>
    <div class="admin-table-card">
        <div class="table-wrap">
            <table class="data-table">
                <thead><tr><th>صورة</th><th>الاسم</th><th>المدينة</th><th>الحالة</th><th>نشط</th><th>إجراءات</th></tr></thead>
                <tbody>
                @foreach (var c in Model)
                {
                    var status = c.IsRejectedByAdmin ? "مرفوض" : c.IsVerified ? "مقبول" : "بانتظار المراجعة";
                    var img = !string.IsNullOrEmpty(c.CoverImagePath) ? c.CoverImagePath : c.LogoImagePath;
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(img))
                            {
                                <img class="table-thumb" src="@img" alt="" width="56" height="56" />
                            }
                            else { <span class="muted">—</span> }
                        </td>
                        <td>@c.ClinicName</td>
                        <td>@c.City</td>
                        <td><span class="badge @(c.IsRejectedByAdmin ? "badge-cancelled" : c.IsVerified ? "badge-approved" : "badge-pending")">@status</span></td>
                        <td>@(c.IsActive ? "نعم" : "لا")</td>
                        <td>
                            <div class="admin-row-actions">
                                @if (c.IsVerified)
                                {
                                    <a class="btn btn-sm btn-outline-edit" asp-controller="Clinic" asp-action="PublicDetails" asp-route-id="@c.ClinicId" target="_blank" rel="noopener">عرض تفاصيل العيادة</a>
                                }
                                @if (!c.IsVerified && !c.IsRejectedByAdmin)
                                {
                                    <form asp-action="VerifyClinic" asp-route-id="@c.ClinicId" method="post" class="admin-row-actions__form">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-primary">قبول</button>
                                    </form>
                                    <form asp-action="RejectClinic" asp-route-id="@c.ClinicId" method="post" class="admin-row-actions__form admin-row-actions__form--wide">
                                        @Html.AntiForgeryToken()
                                        <input type="text" name="note" class="admin-reject-note" placeholder="سبب الرفض (اختياري)" maxlength="500" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Reject this clinic request?');">رفض</button>
                                    </form>
                                }
                                else if (c.IsVerified)
                                {
                                    @if (c.IsActive && c.Owner.IsActive)
                                    {
                                        <form asp-action="SuspendClinic" asp-route-id="@c.ClinicId" method="post" class="admin-row-actions__form" onsubmit="return confirm('Suspend this clinic?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-ghost">تعليق</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="UnsuspendClinic" asp-route-id="@c.ClinicId" method="post" class="admin-row-actions__form">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-unban">إلغاء التعليق</button>
                                        </form>
                                    }
                                }
                                @if (!string.IsNullOrEmpty(c.LicenseDocumentPath))
                                {
                                    <a class="btn btn-sm btn-outline-edit" href="@Url.Action("ViewClinicLicense", new { id = c.ClinicId })" target="_blank" rel="noopener">عرض الوثيقة</a>
                                }
                                <form asp-action="DeleteClinic" asp-route-id="@c.ClinicId" method="post" class="admin-row-actions__form" onsubmit="return confirm('Permanently delete this clinic, all its appointments and services? The owner account will remain. This cannot be undone.');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">حذف نهائي</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
