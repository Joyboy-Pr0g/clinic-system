@model List<ArticleListItemVM>
@{
    ViewData["Title"] = "المقالات والأخبار";
}
<div class="container section-block">
    <h1 class="page-title">المقالات والأخبار</h1>
    <div class="book-steps" style="margin-bottom:1rem">
        <a class="book-step @(ViewBag.Category == null ? "active" : null)" href="@Url.Action("Index")">الكل</a>
        <a class="book-step @(ViewBag.Category as string == ArticleCategories.HealthTips ? "active" : null)" href="@Url.Action("Index", new { category = ArticleCategories.HealthTips })">نصائح</a>
        <a class="book-step @(ViewBag.Category as string == ArticleCategories.News ? "active" : null)" href="@Url.Action("Index", new { category = ArticleCategories.News })">أخبار</a>
        <a class="book-step @(ViewBag.Category as string == ArticleCategories.Guides ? "active" : null)" href="@Url.Action("Index", new { category = ArticleCategories.Guides })">أدلة</a>
    </div>
    <div class="card-grid">
        @foreach (var a in Model)
        {
            <div class="card">
                @if (!string.IsNullOrEmpty(a.ThumbnailImagePath))
                { <img class="card-img-top" src="@a.ThumbnailImagePath" alt="" /> }
                <h3>@a.Title</h3>
                <p class="muted">@(a.Summary ?? "")</p>
                <small class="muted">@a.PublishedAt?.ToLocalTime().ToString("d")</small>
                <a class="btn btn-sm btn-primary" asp-action="Details" asp-route-slug="@a.Slug">قراءة</a>
            </div>
        }
    </div>
</div>
