@model dynamic
<style>
    /* الحاوية الكبيرة للدردشة */
    .appointment-chat-panel {
        background: #fff;
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        height: 600px;
        border: 1px solid #efefef;
    }

    /* منطقة الرسائل — فقاعات واتساب (رسائلك يمين، الطرف الآخر يسار) */
    .appointment-chat-log {
        flex-grow: 1;
        overflow-y: auto;
        padding: 20px;
        background: #e5ddd5;
        max-height: none;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: stretch;
        direction: rtl;
    }

    .appointment-chat-msg {
        max-width: 82%;
        margin-bottom: 0;
        padding: 0.45rem 0.65rem;
        border-radius: 12px;
        box-shadow: 0 1px 1px rgba(0, 0, 0, 0.08);
        background: #fff;
    }

    .appointment-chat-msg--mine {
        align-self: flex-start;
        background: #d9fdd3;
        border-inline-end: none;
        border-inline-start: 3px solid var(--color-primary, #00A884);
    }

    .appointment-chat-msg:not(.appointment-chat-msg--mine) {
        align-self: flex-end;
        background: #fff;
        border: 1px solid rgba(0, 0, 0, 0.06);
    }

    .appointment-chat-msg__who { font-size: 0.72rem; color: #667781; margin-bottom: 0.15rem; }
    .appointment-chat-msg__body { color: #111b21; }

    /* شريط الكتابة (Instagram Style) */
    .ig-composer-wrapper {
        padding: 12px 16px;
        background: #fff;
        border-top: 1px solid #efefef;
    }

    .modern-chat-composer {
        background: #fff;
        border: 1px solid #dbdbdb;
        border-radius: 24px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 10px 12px;
        position: relative;
    }

    /* صف النص: بعرض كامل */
    .chat-composer-input-row {
        width: 100%;
        min-width: 0;
    }

    .appointment-chat-form__input.chat-composer-textarea-full {
        display: block;
        width: 100%;
        min-width: 0;
        box-sizing: border-box;
        border: 1px solid #e5e5e5 !important;
        border-radius: 16px;
        outline: none !important;
        padding: 10px 14px;
        font-size: 0.95rem;
        resize: none;
        max-height: 140px;
        background: #fafafa;
        line-height: 1.45;
    }

    .chat-composer-toolbar {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

    .chat-composer-toolbar__spacer {
        flex: 1;
        min-width: 8px;
    }

    /* الأزرار داخل الشريط */
    .chat-tool-btn {
        background: transparent;
        border: none;
        cursor: pointer;
        color: #262626;
        padding: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: color 0.2s;
    }

    .chat-tool-btn:hover { color: var(--color-primary, #00A884); }
    .chat-tool-btn svg { width: 24px; height: 24px; }

    /* زر الإرسال */
    .chat-send-main-btn {
        background: transparent;
        color: var(--color-primary, #00A884);
        border: none;
        font-weight: 600;
        font-size: 0.95rem;
        padding: 8px 4px;
        cursor: pointer;
        flex-shrink: 0;
    }

    /* معاينة الصوت — تظهر فقط بعد إيقاف التسجيل (يزيل hidden من JS) */
    .voice-overlay-modern[hidden] {
        display: none !important;
    }

    .voice-overlay-modern {
        display: flex;
        align-items: center;
        width: 100%;
        gap: 10px;
        padding: 8px 4px;
        margin-top: 2px;
        background: #f5f5f5;
        border-radius: 16px;
        box-sizing: border-box;
    }

    .voice-preview-stream { flex: 1; min-width: 0; height: 36px; }
    .voice-cancel-x { color: #ed4956; font-weight: 600; cursor: pointer; padding: 0 5px; flex-shrink: 0; }

    /* معاينة صورة/فيديو/مستند قبل الإرسال */
    .media-preview-modern[hidden] { display: none !important; }
    .media-preview-modern {
        display: flex;
        flex-direction: column;
        gap: 8px;
        width: 100%;
        padding: 10px;
        margin-top: 4px;
        background: #f0f2f5;
        border-radius: 16px;
        box-sizing: border-box;
        border: 1px solid #e2e8f0;
    }
    .media-preview-modern__slot { min-height: 48px; max-height: 220px; overflow: auto; text-align: center; }
    .media-preview-modern__slot img,
    .media-preview-modern__slot video { max-width: 100%; max-height: 200px; border-radius: 10px; vertical-align: middle; }
    .media-preview-modern__slot audio { width: 100%; max-width: 320px; }
    .media-preview-modern__filename { font-size: 0.9rem; color: #374151; word-break: break-all; padding: 0.35rem 0; }
    .media-preview-modern__actions {
        display: flex;
        align-items: center;
        gap: 10px;
        justify-content: flex-end;
    }
</style>

    <section class="appointment-chat-panel animate-fade-up" data-chat-appt="@Model.AppointmentId" data-user-role="@Model.UserRole">
    <div class="appointment-chat-log" data-chat-log id="messagesList"></div>

    <form class="appointment-chat-form ig-composer-wrapper" data-chat-form autocomplete="off" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div style="width: 100%;" class="modern-chat-composer">
            <div class="chat-composer-input-row">
                <textarea name="body" maxlength="4000" placeholder="رسالة… (اضغط مطولاً للتسجيل الصوتي)" class="appointment-chat-form__input chat-composer-textarea-full" rows="2" id="chatInput"></textarea>
            </div>

            <div class="chat-composer-toolbar">
                <label class="chat-tool-btn" title="إرفاق ملفات أو مستندات">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    <input type="file" data-chat-media-picker data-chat-file hidden
                           accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.xls,.xlsx,.txt" />
                </label>

                <button type="button" class="chat-tool-btn" title="مشاركة الموقع" data-share-location>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                    </svg>
                </button>

                <button type="button" class="chat-tool-btn" title="تتبع الموقع" data-track-location>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                        <path d="M12 2v2"></path>
                        <path d="M12 20v2"></path>
                        <path d="M2 12h2"></path>
                        <path d="M20 12h2"></path>
                    </svg>
                </button>

                <span class="chat-composer-toolbar__spacer" aria-hidden="true"></span>

                <button type="button" class="chat-tool-btn" data-chat-record-mic id="micBtn" title="تسجيل صوتي">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path>
                        <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
                        <line x1="12" y1="19" x2="12" y2="23"></line>
                        <line x1="8" y1="23" x2="16" y2="23"></line>
                    </svg>
                </button>

                <button type="submit" class="chat-send-main-btn" id="sendBtn" style="display:none;">إرسال</button>
            </div>

            <div class="voice-overlay-modern" data-voice-actions hidden>
                <span class="voice-cancel-x" data-voice-cancel title="رفض التسجيل">رفض</span>
                <audio class="voice-preview-stream" controls data-voice-preview></audio>
                <button type="button" class="chat-send-main-btn" data-voice-send>إرسال</button>
            </div>

            <div class="media-preview-modern" data-media-preview hidden>
                <div class="media-preview-modern__slot" data-media-preview-slot></div>
                <div class="media-preview-modern__filename" data-media-preview-name hidden></div>
                <div class="media-preview-modern__actions">
                    <span class="voice-cancel-x" data-media-preview-cancel title="رفض المرفق">رفض</span>
                    <button type="button" class="chat-send-main-btn" data-media-preview-send>إرسال</button>
                </div>
            </div>
        </div>
    </form>
</section>

<script src="~/js/appointment-chat-rich.js" asp-append-version="true" defer></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const chatInput = document.getElementById('chatInput');
        const sendBtn = document.getElementById('sendBtn');
        const micBtn = document.getElementById('micBtn');
        if (!chatInput || !sendBtn || !micBtn) return;

        chatInput.addEventListener('input', function () {
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';

            if (this.value.trim().length > 0) {
                sendBtn.style.display = 'block';
                micBtn.style.display = 'none';
            } else {
                sendBtn.style.display = 'none';
                micBtn.style.display = 'flex';
            }
        });
    });
</script>
