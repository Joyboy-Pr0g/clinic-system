@model PatientDashboardVM
@{
    ViewData["Title"] = "لوحة المريض";
}
@section Sidebar { <partial name="_Sidebar" /> }

<h1 class="page-title">مرحباً</h1>
<div class="stat-cards">
    <div class="stat-card"><strong>@Model.TotalBookings</strong><div class="muted">إجمالي الحجوزات</div></div>
    <div class="stat-card"><strong>@Model.Upcoming</strong><div class="muted">قادمة</div></div>
    <div class="stat-card"><strong>@Model.Completed</strong><div class="muted">مكتملة</div></div>
    <div class="stat-card"><strong>@Model.Pending</strong><div class="muted">معلقة</div></div>
</div>
<a class="btn btn-accent" asp-action="Book">احجز موعداً</a>
<h2 class="page-title" style="margin-top:2rem">آخر المواعيد</h2>
<div class="table-wrap">
    <table class="data-table">
        <thead><tr><th>التاريخ</th><th>المقدم</th><th>الخدمة</th><th>الحالة</th><th></th></tr></thead>
        <tbody>
        @foreach (var r in Model.RecentAppointments)
        {
            <tr>
                <td>@r.AppointmentDate.ToLocalTime().ToString("g")</td>
                <td>@r.ProviderName</td>
                <td>@r.ServiceName</td>
                <td><span class="badge badge-@(r.Status == "InProgress" ? "inprogress" : r.Status.ToLowerInvariant())">@r.Status</span></td>
                <td><a asp-action="AppointmentDetail" asp-route-id="@r.AppointmentId">تفاصيل</a></td>
            </tr>
        }
        </tbody>
    </table>
</div>
