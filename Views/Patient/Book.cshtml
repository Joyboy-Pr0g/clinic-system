@* hksdfksjd *@

@model AppointmentBookVM
@{
    ViewData["Title"] = "حجز موعد";
    var nurses = ViewBag.Nurses as IReadOnlyList<NurseListItemVM>;
    var clinics = ViewBag.Clinics as IReadOnlyList<ClinicListItemVM>;
    var services = ViewBag.Services as IEnumerable<HomeNursingSystem.Models.MedicalService>;
}
@section Sidebar { <partial name="_Sidebar" /> }

<h1 class="page-title">حجز موعد</h1>
<div class="book-steps">
    <span class="book-step active" data-step-indicator="1">1 النوع</span>
    <span class="book-step" data-step-indicator="2">2 التفاصيل</span>
    <span class="book-step" data-step-indicator="3">3 تأكيد</span>
</div>

<form asp-action="Book" method="post" class="form-stack wide" data-loading id="book-form">
    @Html.AntiForgeryToken()
    <div data-book-step="1">
        <label><input type="radio" asp-for="BookType" value="Nurse" checked="@(Model.BookType=="Nurse")" /> ممرض منزلي</label>
        <label><input type="radio" asp-for="BookType" value="Clinic" checked="@(Model.BookType=="Clinic")" /> عيادة</label>
        <div class="field nurse-pick">
            <label>الممرض</label>
            <select asp-for="NurseProfileId" asp-items="@(new SelectList(nurses ?? Array.Empty<NurseListItemVM>(), "NurseProfileId", "FullName"))">
                <option value="">— اختر —</option>
            </select>
        </div>
        <div class="field clinic-pick">
            <label>العيادة</label>
            <select asp-for="ClinicId" asp-items="@(new SelectList(clinics ?? Array.Empty<ClinicListItemVM>(), "ClinicId", "ClinicName"))">
                <option value="">— اختر —</option>
            </select>
        </div>
        <button type="button" class="btn btn-primary" data-next-step>التالي</button>
    </div>
    <div data-book-step="2" style="display:none">
        <div class="field">
            <label asp-for="ServiceId"></label>
            <select asp-for="ServiceId" asp-items="@(new SelectList(services ?? Enumerable.Empty<HomeNursingSystem.Models.MedicalService>(), "ServiceId", "ServiceName"))"></select>
            <span asp-validation-for="ServiceId"></span>
        </div>
        <div class="field field-ltr">
            <label asp-for="AppointmentDate"></label>
            <input asp-for="AppointmentDate" type="datetime-local" />
            <span asp-validation-for="AppointmentDate"></span>
        </div>
        <div class="field">
            <label asp-for="AddressText"></label>
            <input asp-for="AddressText" />
            <span asp-validation-for="AddressText"></span>
        </div>
        <div class="field"><label asp-for="Notes"></label><textarea asp-for="Notes" rows="2"></textarea></div>
        <p class="muted">حدد موقعك على الخريطة (اسحب العلامة)</p>
        <div id="map" class="map-canvas"></div>
        <input type="hidden" asp-for="Latitude" id="lat-input" />
        <input type="hidden" asp-for="Longitude" id="lng-input" />
        <button type="button" class="btn btn-ghost" data-prev-step>السابق</button>
        <button type="button" class="btn btn-primary" data-next-step>التالي</button>
    </div>
    <div data-book-step="3" style="display:none">
        <p>راجع البيانات ثم أرسل الطلب.</p>
        <button type="button" class="btn btn-ghost" data-prev-step>السابق</button>
        <button type="submit" class="btn btn-accent">تأكيد الحجز</button>
    </div>
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (!string.IsNullOrEmpty(Model.GoogleMapsApiKey) && Model.GoogleMapsApiKey != "YOUR_GOOGLE_MAPS_API_KEY")
    {
        <script src="https://maps.googleapis.com/maps/api/js?key=@Model.GoogleMapsApiKey&libraries=marker"></script>
        <script>
            (function () {
                var latEl = document.getElementById("lat-input");
                var lngEl = document.getElementById("lng-input");
                var defLat = parseFloat(latEl.value) || 24.7136;
                var defLng = parseFloat(lngEl.value) || 46.6753;
                window.initBookMap = function () {
                    var map = new google.maps.Map(document.getElementById("map"), {
                        center: { lat: defLat, lng: defLng },
                        zoom: 12
                    });
                    var marker = new google.maps.Marker({
                        map: map,
                        position: { lat: defLat, lng: defLng },
                        draggable: true
                    });
                    function save() {
                        var p = marker.getPosition();
                        latEl.value = p.lat();
                        lngEl.value = p.lng();
                    }
                    marker.addListener("dragend", save);
                    map.addListener("click", function (e) {
                        marker.setPosition(e.latLng);
                        save();
                    });
                    save();
                };
                if (window.google && google.maps) initBookMap();
            })();
        </script>
        <script>if (window.google && google.maps) { if (typeof initBookMap === 'function') initBookMap(); }</script>
    }
    <script>
        (function () {
            var step = 1;
            function show(s) {
                document.querySelectorAll("[data-book-step]").forEach(function (el) {
                    el.style.display = el.getAttribute("data-book-step") == s ? "block" : "none";
                });
                document.querySelectorAll("[data-step-indicator]").forEach(function (el, i) {
                    el.classList.toggle("active", i + 1 <= s);
                });
                step = s;
            }
            document.querySelectorAll("[data-next-step]").forEach(function (b) {
                b.addEventListener("click", function () { show(Math.min(3, step + 1)); });
            });
            document.querySelectorAll("[data-prev-step]").forEach(function (b) {
                b.addEventListener("click", function () { show(Math.max(1, step - 1)); });
            });
            function toggleType() {
                var t = document.querySelector("input[name=\"BookType\"]:checked");
                var n = document.querySelector(".nurse-pick");
                var c = document.querySelector(".clinic-pick");
                if (!t) return;
                n.style.display = t.value === "Nurse" ? "block" : "none";
                c.style.display = t.value === "Clinic" ? "block" : "none";
            }
            document.querySelectorAll("input[name=\"BookType\"]").forEach(function (r) {
                r.addEventListener("change", toggleType);
            });
            toggleType();
            show(1);
        })();
    </script>
}
