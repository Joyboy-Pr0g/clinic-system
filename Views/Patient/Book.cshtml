@model AppointmentBookVM
@using System.Globalization
@using HomeNursingSystem.Models
@{
    ViewData["Title"] = "حجز موعد";
    var nurses = ViewBag.Nurses as IReadOnlyList<NurseListItemVM> ?? Array.Empty<NurseListItemVM>();
    var clinics = ViewBag.Clinics as IReadOnlyList<ClinicListItemVM> ?? Array.Empty<ClinicListItemVM>();
    var nurseServicesJson = ViewBag.NurseServicesJson as string ?? "[]";
    var clinicServicesJson = ViewBag.ClinicServicesJson as string ?? "[]";
    var providerLocked = ViewBag.ProviderLocked as bool? ?? false;
    var providerDisplayName = ViewBag.ProviderDisplayName as string ?? "";
    var detailStep = providerLocked ? 1 : 2;
    var confirmStep = providerLocked ? 2 : 3;
    var maxStep = providerLocked ? 2 : 3;
    var apptUtcHidden = Model.AppointmentDate.Year >= 2000
        ? (Model.AppointmentDate.Kind == DateTimeKind.Utc ? Model.AppointmentDate : Model.AppointmentDate.ToUniversalTime())
        : (DateTime?)null;
    var apptHiddenValue = apptUtcHidden.HasValue
        ? apptUtcHidden.Value.ToString("yyyy-MM-dd'T'HH:mm:ss.fff'Z'", CultureInfo.InvariantCulture)
        : "";
}
@section Sidebar { <partial name="_Sidebar" /> }

<h1 class="page-title">حجز موعد</h1>

<div class="book-layout">
<div class="form-card" style="margin:0">
@if (providerLocked && !string.IsNullOrWhiteSpace(providerDisplayName))
{
    <p class="book-provider-lock">
        أنت تحجز مع <strong>@providerDisplayName</strong> — أكمل الخدمة والموقع والتأكيد أدناه.
    </p>
}

<div class="book-steps">
    @if (providerLocked)
    {
        <span class="book-step active" data-step-indicator="1">1 التفاصيل</span>
        <span class="book-step" data-step-indicator="2">2 تأكيد</span>
    }
    else
    {
        <span class="book-step active" data-step-indicator="1">1 النوع</span>
        <span class="book-step" data-step-indicator="2">2 التفاصيل</span>
        <span class="book-step" data-step-indicator="3">3 تأكيد</span>
    }
</div>

<form asp-action="Book" method="post" class="form-stack wide" style="max-width:none" data-loading id="book-form">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="GoogleMapsApiKey" />
    @if (providerLocked)
    {
        <input type="hidden" asp-for="BookType" />
        @if (string.Equals(Model.BookType, "Nurse", StringComparison.OrdinalIgnoreCase) && (Model.NurseProfileId ?? 0) > 0)
        {
            <input type="hidden" asp-for="NurseProfileId" />
        }
        @if (string.Equals(Model.BookType, "Clinic", StringComparison.OrdinalIgnoreCase) && (Model.ClinicId ?? 0) > 0)
        {
            <input type="hidden" asp-for="ClinicId" />
        }
    }
    @if (!providerLocked)
    {
        <div data-book-step="1">
            <p class="text-danger book-step-validation-msg" data-step-validation-msg style="display:none;margin:0 0 0.75rem;font-weight:600" role="alert"></p>
            <label><input type="radio" asp-for="BookType" value="Nurse" /> ممرض منزلي</label>
            <label><input type="radio" asp-for="BookType" value="Clinic" /> عيادة</label>
            <div class="field nurse-pick">
                <label>الممرض</label>
                <select asp-for="NurseProfileId" asp-items="@(new SelectList(nurses, "NurseProfileId", "FullName"))">
                    <option value="">— اختر —</option>
                </select>
            </div>
            <div class="field clinic-pick">
                <label>العيادة</label>
                <select asp-for="ClinicId" asp-items="@(new SelectList(clinics, "ClinicId", "ClinicName"))">
                    <option value="">— اختر —</option>
                </select>
            </div>
            <button style="margin-top: 1rem;" type="button" class="btn btn-primary" data-next-step>التالي</button>
        </div>
    }
    <div data-book-step="@detailStep" style="display:none">
        <p class="text-danger book-step-validation-msg" data-step-validation-msg style="display:none;margin:0 0 0.75rem;font-weight:600" role="alert"></p>
        <div class="field service-pick-nurse">
            <label asp-for="NurseListingServiceId">خدمة الممرض</label>
            <select asp-for="NurseListingServiceId">
                <option value="0">— اختر الخدمة —</option>
            </select>
            <span asp-validation-for="NurseListingServiceId"></span>
            <p class="muted" style="margin:0.35rem 0 0;font-size:0.88rem;display:none" data-nurse-services-empty>هذا الممرض لم يضف خدمات بعد أو لا توجد خدمات متاحة؛ اختر ممرضاً آخر أو تواصل معه.</p>
        </div>
        <div class="field service-pick-clinic" style="display:none">
            <label asp-for="ClinicServiceId">خدمة العيادة</label>
            <select asp-for="ClinicServiceId">
                <option value="">— اختر خدمة العيادة —</option>
            </select>
            <span asp-validation-for="ClinicServiceId"></span>
            <p class="muted" style="margin:0.35rem 0 0;font-size:0.88rem;display:none" data-clinic-services-empty>هذه العيادة لم تضف خدمات بعد؛ تواصل مع العيادة أو جرّب لاحقاً.</p>
        </div>
        <div class="field book-slot-field">
            <label style="text-align: right;" asp-for="AppointmentDate">موعد الزيارة</label>
            <p class="muted book-slot-field__hint" style="margin:0 0 0.5rem;font-size:0.9rem" data-book-slot-hint>اختر اليوم ثم الساعة من الأوقات المتاحة لدى مقدم الخدمة.</p>
            <div class="book-week-strip" data-book-week-strip role="group" aria-label="أيام الأسبوع"></div>
            <div class="book-time-chips" data-book-time-chips role="group" aria-label="الأوقات"></div>
            <input type="hidden" name="AppointmentDate" id="AppointmentDate" value="@apptHiddenValue" autocomplete="off" />
            <span asp-validation-for="AppointmentDate"></span>
        </div>
        <div class="field">
            <label asp-for="AddressText"></label>
            <input asp-for="AddressText" />
            <span asp-validation-for="AddressText"></span>
        </div>
        <div class="field"><label asp-for="Notes"></label><textarea asp-for="Notes" rows="2"></textarea></div>
        @if (!string.IsNullOrEmpty(Model.GoogleMapsApiKey) && Model.GoogleMapsApiKey != "YOUR_GOOGLE_MAPS_API_KEY")
        {
            <p class="muted">حدد موقعك على الخريطة (اسحب العلامة)</p>
            <div id="map" class="map-canvas"></div>
        }
        else
        {
            <p class="muted text-danger">مفتاح خرائط Google غير مضبوط في التطبيق؛ يمكنك إدخال العنوان نصياً فقط.</p>
        }
        <input type="hidden" asp-for="Latitude" id="lat-input" />
        <input type="hidden" asp-for="Longitude" id="lng-input" />
        <button type="button" class="btn btn-ghost" data-prev-step>السابق</button>
        <button type="button" class="btn btn-primary" data-next-step>التالي</button>
    </div>
    <div data-book-step="@confirmStep" style="display:none">
        <p>راجع البيانات ثم أرسل الطلب.</p>
        <button type="button" class="btn btn-ghost" data-prev-step>السابق</button>
        <button type="submit" class="btn btn-accent">تأكيد الحجز</button>
    </div>
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
</form>
</div>
<aside class="book-summary" aria-label="ملخص الحجز">
    <h3>ملخص سريع</h3>
    <ul class="muted" style="padding-inline-start:1.1rem;margin:0;font-size:0.95rem;line-height:1.7">
        <li>اختر الممرض أو العيادة</li>
        <li>حدد الخدمة ثم اليوم والساعة من جدول التوفر</li>
        <li>أدخل العنوان أو الموقع على الخريطة</li>
        <li>راجع ثم أرسل الطلب</li>
    </ul>
    <p class="muted" style="font-size:0.85rem;margin:1rem 0 0">بعد الإرسال ستصلك حالة الطلب من مقدم الخدمة.</p>
</aside>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @if (!string.IsNullOrEmpty(Model.GoogleMapsApiKey) && Model.GoogleMapsApiKey != "YOUR_GOOGLE_MAPS_API_KEY")
    {
        <script src="https://maps.googleapis.com/maps/api/js?key=@Model.GoogleMapsApiKey"></script>
        <script>
            (function () {
                var latEl = document.getElementById("lat-input");
                var lngEl = document.getElementById("lng-input");
                var mapEl = document.getElementById("map");
                if (!mapEl || !latEl || !lngEl) return;
                var defLat = parseFloat(latEl.value) || 24.7136;
                var defLng = parseFloat(lngEl.value) || 46.6753;
                function initBookMap() {
                    if (!window.google || !google.maps) return;
                    var map = new google.maps.Map(mapEl, {
                        center: { lat: defLat, lng: defLng },
                        zoom: 12
                    });
                    var marker = new google.maps.Marker({
                        map: map,
                        position: { lat: defLat, lng: defLng },
                        draggable: true
                    });
                    function save() {
                        var p = marker.getPosition();
                        latEl.value = p.lat();
                        lngEl.value = p.lng();
                    }
                    marker.addListener("dragend", save);
                    map.addListener("click", function (e) {
                        marker.setPosition(e.latLng);
                        save();
                    });
                    save();
                }
                if (window.google && google.maps) initBookMap();
                else window.addEventListener("load", initBookMap);
            })();
        </script>
    }
    <script>
        (function () {
            var maxStep = @maxStep;
            var minStep = 1;
            var step = 1;
            var providerLocked = @(providerLocked ? "true" : "false");
            var detailStep = @detailStep;
            var clinicServicesCatalog = @Html.Raw(clinicServicesJson);
            var nurseServicesCatalog = @Html.Raw(nurseServicesJson);
            var availabilityData = null;

            function clearSlotPicker() {
                availabilityData = null;
                var strip = document.querySelector("[data-book-week-strip]");
                var chips = document.querySelector("[data-book-time-chips]");
                if (strip) strip.innerHTML = "";
                if (chips) chips.innerHTML = "";
                var h = document.getElementById("AppointmentDate");
                if (h) h.value = "";
            }

            function fetchAvailability() {
                var nurseEl = document.querySelector('select[name="NurseProfileId"]') || document.querySelector('input[name="NurseProfileId"]');
                var clinicEl = document.querySelector('select[name="ClinicId"]') || document.querySelector('input[name="ClinicId"]');
                var url = "/patient/book/availability?";
                if (isClinicBooking()) {
                    var cid = clinicEl && clinicEl.value ? clinicEl.value : "";
                    if (!cid) { clearSlotPicker(); return; }
                    url += "clinicId=" + encodeURIComponent(cid);
                } else {
                    var npid = nurseEl && nurseEl.value ? nurseEl.value : "";
                    if (!npid) { clearSlotPicker(); return; }
                    url += "nurseProfileId=" + encodeURIComponent(npid);
                }
                fetch(url)
                    .then(function (res) {
                        if (!res.ok) { clearSlotPicker(); return null; }
                        return res.json();
                    })
                    .then(function (data) {
                        if (!data) return;
                        availabilityData = data;
                        renderSlotPicker();
                    })
                    .catch(function () { clearSlotPicker(); });
            }

            function renderSlotPicker() {
                var strip = document.querySelector("[data-book-week-strip]");
                var chips = document.querySelector("[data-book-time-chips]");
                var hint = document.querySelector("[data-book-slot-hint]");
                if (!strip || !chips) return;
                strip.innerHTML = "";
                chips.innerHTML = "";
                if (!availabilityData || !availabilityData.days || !availabilityData.days.length) {
                    if (hint) hint.textContent = "لا توجد أوقات في الجدول لهذا المقدّم. اختر جهة أخرى أو اطلب تحديث أوقات التوفر.";
                    return;
                }
                var hasAny = availabilityData.days.some(function (d) { return d.slots && d.slots.length; });
                if (hint) {
                    hint.textContent = hasAny
                        ? "اختر اليوم ثم الساعة من الأوقات المتاحة لدى مقدم الخدمة."
                        : "لا توجد أوقات متاحة في الأسبوع القادم. جرّب مقدّماً آخر.";
                }
                if (!hasAny) return;

                var hiddenEl = document.getElementById("AppointmentDate");
                var presetUtc = hiddenEl && hiddenEl.value ? hiddenEl.value : "";
                var presetDayIdx = -1;
                if (presetUtc) {
                    availabilityData.days.forEach(function (d, i) {
                        if (presetDayIdx >= 0) return;
                        if ((d.slots || []).some(function (s) { return s.utcIso === presetUtc; })) presetDayIdx = i;
                    });
                }
                availabilityData.days.forEach(function (day) {
                    var btn = document.createElement("button");
                    btn.type = "button";
                    btn.className = "book-week-day" + (day.slots && day.slots.length ? "" : " book-week-day--empty");
                    btn.textContent = day.weekdayLabel || day.date || "";
                    btn.disabled = !day.slots || day.slots.length === 0;
                    btn.addEventListener("click", function () {
                        strip.querySelectorAll(".book-week-day").forEach(function (b) { b.classList.remove("is-active"); });
                        btn.classList.add("is-active");
                        var h = document.getElementById("AppointmentDate");
                        var cur = h ? h.value : "";
                        var stillValid = (day.slots || []).some(function (s) { return s.utcIso === cur; });
                        if (h && !stillValid) h.value = "";
                        renderTimeChips(day);
                    });
                    strip.appendChild(btn);
                });
                var firstIdx = presetDayIdx >= 0 ? presetDayIdx : availabilityData.days.findIndex(function (d) { return d.slots && d.slots.length; });
                if (firstIdx >= 0 && strip.children[firstIdx]) strip.children[firstIdx].click();
            }

            function renderTimeChips(day) {
                var chips = document.querySelector("[data-book-time-chips]");
                if (!chips) return;
                chips.innerHTML = "";
                var hidden = document.getElementById("AppointmentDate");
                var cur = hidden ? hidden.value : "";
                (day.slots || []).forEach(function (slot) {
                    var b = document.createElement("button");
                    b.type = "button";
                    b.className = "book-time-chip";
                    b.textContent = slot.timeLabel || "";
                    if (cur && slot.utcIso === cur) b.classList.add("is-active");
                    b.addEventListener("click", function () {
                        chips.querySelectorAll(".book-time-chip").forEach(function (x) { x.classList.remove("is-active"); });
                        b.classList.add("is-active");
                        if (hidden) hidden.value = slot.utcIso;
                    });
                    chips.appendChild(b);
                });
            }

            function clearStepMessages() {
                document.querySelectorAll("[data-step-validation-msg]").forEach(function (el) {
                    el.textContent = "";
                    el.style.display = "none";
                });
            }

            function setStepMessage(stepNum, msg) {
                var panel = document.querySelector('[data-book-step="' + stepNum + '"]');
                if (!panel) return;
                var el = panel.querySelector("[data-step-validation-msg]");
                if (!el) return;
                if (msg) {
                    el.textContent = msg;
                    el.style.display = "block";
                } else {
                    el.textContent = "";
                    el.style.display = "none";
                }
            }

            function validateTypeStep() {
                var t = document.querySelector('input[name="BookType"]:checked');
                if (!t) {
                    setStepMessage(1, "يرجى اختيار نوع الحجز (ممرض منزلي أو عيادة).");
                    return false;
                }
                if (t.value === "Nurse") {
                    var sel = document.querySelector('select[name="NurseProfileId"]');
                    if (!sel || !sel.value || sel.value === "0") {
                        setStepMessage(1, "يرجى اختيار الممرض من القائمة.");
                        return false;
                    }
                } else {
                    var selc = document.querySelector('select[name="ClinicId"]');
                    if (!selc || !selc.value || selc.value === "0") {
                        setStepMessage(1, "يرجى اختيار العيادة من القائمة.");
                        return false;
                    }
                }
                setStepMessage(1, "");
                return true;
            }

            function isClinicBooking() {
                if (providerLocked) {
                    var cid = document.querySelector('input[name="ClinicId"]');
                    return !!(cid && cid.value && cid.value !== "0");
                }
                var t = document.querySelector('input[name="BookType"]:checked');
                return !!(t && t.value === "Clinic");
            }

            function fillNurseServices(nurseProfileId) {
                var sel = document.querySelector('select[name="NurseListingServiceId"]');
                var emptyHint = document.querySelector("[data-nurse-services-empty]");
                if (!sel) return;
                var prev = sel.value;
                sel.innerHTML = '<option value=\"0\">— اختر الخدمة —</option>';
                var id = parseInt(String(nurseProfileId || "0"), 10);
                var rows = (nurseServicesCatalog || []).filter(function (x) { return x.nurseProfileId === id; });
                rows.forEach(function (x) {
                    var o = document.createElement("option");
                    o.value = String(x.nurseListingServiceId);
                    o.textContent = x.name + " — " + Number(x.price).toFixed(2) + " ر.س";
                    sel.appendChild(o);
                });
                if (prev && rows.some(function (x) { return String(x.nurseListingServiceId) === prev; }))
                    sel.value = prev;
                if (emptyHint) {
                    emptyHint.style.display = rows.length ? "none" : "block";
                }
            }

            function fillClinicServices(clinicId) {
                var sel = document.querySelector('select[name="ClinicServiceId"]');
                var emptyHint = document.querySelector("[data-clinic-services-empty]");
                if (!sel) return;
                var prev = sel.value;
                sel.innerHTML = '<option value=\"\">— اختر خدمة العيادة —</option>';
                var id = parseInt(String(clinicId || "0"), 10);
                var rows = (clinicServicesCatalog || []).filter(function (x) { return x.clinicId === id; });
                rows.forEach(function (x) {
                    var o = document.createElement("option");
                    o.value = String(x.clinicServiceId);
                    o.textContent = x.name + " — " + Number(x.price).toFixed(2) + " ر.س";
                    sel.appendChild(o);
                });
                if (prev && rows.some(function (x) { return String(x.clinicServiceId) === prev; }))
                    sel.value = prev;
                if (emptyHint) {
                    emptyHint.style.display = rows.length ? "none" : "block";
                }
            }

            function refreshServicePickVisibility() {
                var nurseField = document.querySelector(".service-pick-nurse");
                var clinicField = document.querySelector(".service-pick-clinic");
                if (!nurseField || !clinicField) return;
                var clinic = isClinicBooking();
                nurseField.style.display = clinic ? "none" : "block";
                clinicField.style.display = clinic ? "block" : "none";
                if (clinic) {
                    var cidEl = document.querySelector('select[name="ClinicId"]') || document.querySelector('input[name="ClinicId"]');
                    var cid = cidEl ? cidEl.value : "";
                    fillClinicServices(cid);
                } else {
                    var npEl = document.querySelector('select[name="NurseProfileId"]') || document.querySelector('input[name="NurseProfileId"]');
                    var npid = npEl ? npEl.value : "";
                    fillNurseServices(npid);
                }
                fetchAvailability();
            }

            function validateDetailsStep() {
                if (isClinicBooking()) {
                    var cs = document.querySelector('select[name="ClinicServiceId"]');
                    if (!cs || !cs.value) {
                        setStepMessage(detailStep, "يرجى اختيار خدمة العيادة.");
                        return false;
                    }
                } else {
                    var service = document.querySelector('select[name="NurseListingServiceId"]');
                    if (!service || !service.value || service.value === "0") {
                        setStepMessage(detailStep, "يرجى اختيار الخدمة.");
                        return false;
                    }
                }
                var dt = document.getElementById("AppointmentDate");
                if (!dt || !String(dt.value || "").trim()) {
                    setStepMessage(detailStep, "يرجى اختيار اليوم والساعة من جدول التوفر.");
                    return false;
                }
                var addr = document.querySelector('input[name="AddressText"]');
                if (!addr || !String(addr.value || "").trim()) {
                    setStepMessage(detailStep, "يرجى إدخال عنوان الزيارة.");
                    return false;
                }
                setStepMessage(detailStep, "");
                return true;
            }

            function canLeaveStep(currentStep) {
                if (providerLocked) {
                    if (currentStep === 1) return validateDetailsStep();
                    return true;
                }
                if (currentStep === 1) return validateTypeStep();
                if (currentStep === detailStep) return validateDetailsStep();
                return true;
            }

            function show(s) {
                clearStepMessages();
                document.querySelectorAll("[data-book-step]").forEach(function (el) {
                    el.style.display = el.getAttribute("data-book-step") == s ? "block" : "none";
                });
                document.querySelectorAll("[data-step-indicator]").forEach(function (el, i) {
                    el.classList.toggle("active", i + 1 <= s);
                });
                step = s;
            }

            document.querySelectorAll("[data-next-step]").forEach(function (b) {
                b.addEventListener("click", function () {
                    var cur = step;
                    if (!canLeaveStep(cur)) return;
                    if (cur === 1) {
                        if (isClinicBooking()) {
                            var cidEl = document.querySelector('select[name="ClinicId"]') || document.querySelector('input[name="ClinicId"]');
                            if (cidEl) fillClinicServices(cidEl.value);
                        } else {
                            var npEl = document.querySelector('select[name="NurseProfileId"]') || document.querySelector('input[name="NurseProfileId"]');
                            if (npEl) fillNurseServices(npEl.value);
                        }
                    }
                    var nextStep = Math.min(maxStep, cur + 1);
                    show(nextStep);
                    if (nextStep === detailStep) fetchAvailability();
                });
            });
            document.querySelectorAll("[data-prev-step]").forEach(function (b) {
                b.addEventListener("click", function () {
                    clearStepMessages();
                    show(Math.max(minStep, step - 1));
                });
            });
            function toggleType() {
                if (providerLocked) return;
                var t = document.querySelector("input[name=\"BookType\"]:checked");
                var n = document.querySelector(".nurse-pick");
                var c = document.querySelector(".clinic-pick");
                if (!t || !n || !c) return;
                n.style.display = t.value === "Nurse" ? "block" : "none";
                c.style.display = t.value === "Clinic" ? "block" : "none";
            }
            document.querySelectorAll("input[name=\"BookType\"]").forEach(function (r) {
                r.addEventListener("change", function () {
                    toggleType();
                    refreshServicePickVisibility();
                });
            });
            var clinicSel = document.querySelector('select[name="ClinicId"]');
            if (clinicSel) {
                clinicSel.addEventListener("change", function () {
                    if (isClinicBooking()) {
                        fillClinicServices(clinicSel.value);
                        fetchAvailability();
                    }
                });
            }
            var nurseSel = document.querySelector('select[name="NurseProfileId"]');
            if (nurseSel) {
                nurseSel.addEventListener("change", function () {
                    if (!isClinicBooking()) {
                        fillNurseServices(nurseSel.value);
                        fetchAvailability();
                    }
                });
            }
            toggleType();
            refreshServicePickVisibility();
            show(providerLocked ? 1 : 1);
        })();
    </script>
}
