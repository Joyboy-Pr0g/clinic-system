@model List<HomeNursingSystem.Models.Rating>
@{ Layout = "_DashboardLayout"; ViewData["Title"] = "تقييماتي"; }
@section Sidebar { <partial name="_Sidebar" /> }

<h1 class="page-title">التقييمات</h1>
<div class="table-wrap">
    <table class="data-table">
        <thead><tr><th>النجوم</th><th>التعليق</th><th>المريض</th><th>التاريخ</th></tr></thead>
        <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td><span class="stars-readonly">@string.Join("", Enumerable.Repeat("★", r.Stars))</span></td>
                <td>@r.Comment</td>
                <td>@r.Patient.FullName</td>
                <td>@r.CreatedAt.ToLocalTime().ToString("g")</td>
            </tr>
        }
        </tbody>
    </table>
</div>
