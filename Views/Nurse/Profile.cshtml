@model NurseProfileEditVM
@{ Layout = "_DashboardLayout"; ViewData["Title"] = "ملف الممرض"; }
@section Sidebar { <partial name="_Sidebar" /> }

<h1 class="page-title">ملفي والخدمات</h1>
<div class="form-card">
    <form asp-action="Profile" method="post" enctype="multipart/form-data" class="form-stack wide" style="max-width:none" data-loading>
        @Html.AntiForgeryToken()
        <h3 class="form-section-title" style="margin-top:0">الملف الشخصي</h3>
        <div class="form-grid-3">
            <div class="field">
                <label asp-for="Specialization"></label>
                <input asp-for="Specialization" readonly />
                <span asp-validation-for="Specialization"></span>
            </div>
            <div class="field">
                <label asp-for="YearsOfExperience"></label>
                <input asp-for="YearsOfExperience" />
                <span asp-validation-for="YearsOfExperience"></span>
            </div>
            <div class="field field--checkbox">
                <label class="field__checkbox-row">
                    <input type="checkbox" asp-for="IsAvailable" /> 
                    @Html.DisplayNameFor(m => m.IsAvailable)
                </label>
            </div>
            <div class="field field-full">
                <label asp-for="Bio"></label>
                <textarea asp-for="Bio" rows="3"></textarea>
                <span asp-validation-for="Bio"></span>
            </div>
            <div class="field field-full">
                <label asp-for="ProfileImage"></label>
                <input asp-for="ProfileImage" type="file" accept="image/*" />
                <span asp-validation-for="ProfileImage"></span>
            </div>
        </div>

        <button type="submit" class="btn btn-primary">حفظ الكل</button>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
