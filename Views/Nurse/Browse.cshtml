@model IReadOnlyList<NurseListItemVM>
@{
    ViewData["Title"] = "الممرضون";
    var services = ViewBag.Services as IEnumerable<HomeNursingSystem.Models.MedicalService>;
}
<h1 class="page-title container">تصفح الممرضين</h1>
<div class="container">
<form method="get" class="card" style="margin-bottom:1.5rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:0.75rem;align-items:end">
    <div class="field"><label>الحي</label><input name="neighborhood" value="@ViewBag.Neighborhood" /></div>
    <div class="field"><label>الخدمة</label>
        <select name="serviceId">
            <option value="">—</option>
            @foreach (var s in services ?? Enumerable.Empty<HomeNursingSystem.Models.MedicalService>())
            {
                <option value="@s.ServiceId" selected="@(ViewBag.ServiceId as int? == s.ServiceId)">@s.ServiceName</option>
            }
        </select>
    </div>
    <div class="field"><label>أقل تقييم</label><input name="minRating" type="number" step="0.1" value="@ViewBag.MinRating" /></div>
    <div class="field"><label><input type="checkbox" name="available" value="true" checked="@(ViewBag.Available as bool? == true)" /> متاح فقط</label></div>
    <div class="field"><label>بحث</label><input name="search" value="@ViewBag.Search" /></div>
    <button class="btn btn-primary" type="submit">تصفية</button>
</form>
<div class="card-grid">
@foreach (var n in Model)
{
    <div class="card">
        @if (!string.IsNullOrEmpty(n.ProfileImage)) { <img class="card-img-top" src="@n.ProfileImage" alt="" /> }
        <h3>@n.FullName</h3>
        <p class="muted">@n.Specialization · @(n.Neighborhood ?? "")</p>
        <p class="stars-readonly">@string.Join("", Enumerable.Repeat("★", (int)Math.Round((double)n.AverageRating)))<span class="muted">(@n.TotalReviews)</span></p>
        <p class="muted">@string.Join("، ", n.ServiceNames)</p>
        <a class="btn btn-sm btn-primary" asp-action="Details" asp-route-id="@n.NurseProfileId">الملف</a>
    </div>
}
</div>
</div>
