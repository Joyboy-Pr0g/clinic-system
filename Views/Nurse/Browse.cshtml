@model IReadOnlyList<NurseListItemVM>
@{
    ViewData["Title"] = "الممرضون";
    var services = ViewBag.Services as IEnumerable<HomeNursingSystem.Models.MedicalService>;
}
<section class="page-hero">
    <div class="container">
        <nav class="breadcrumb" aria-label="مسار التنقل">
            <a asp-controller="Home" asp-action="Index">الرئيسية</a>
            <span> / </span>
            <span>الممرضون</span>
        </nav>
        <h1>تصفح الممرضين</h1>
    </div>
</section>

<div style="width: 100%; margin: 0 auto; padding: 0 1rem;" class="container section-block">
    <form method="get" class="form-card" style="margin-bottom:1.5rem">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:0.85rem;align-items:end">
            <div class="field"><label>الحي</label><input name="neighborhood" value="@ViewBag.Neighborhood" /></div>
            <div class="field"><label>الخدمة</label>
                <select name="serviceId">
                    <option value="">الكل</option>
                    @foreach (var s in services ?? Enumerable.Empty<HomeNursingSystem.Models.MedicalService>())
                    {
                        <option value="@s.ServiceId" selected="@(ViewBag.ServiceId as int? == s.ServiceId)">@s.ServiceName</option>
                    }
                </select>
            </div>
            <div class="field"><label>أقل تقييم</label><input name="minRating" type="number" step="0.1" value="@ViewBag.MinRating" /></div>
            <div class="field"><label>بحث</label><input name="search" value="@ViewBag.Search" placeholder="الاسم أو التخصص" /></div>
            <div class="field" style="display:flex;align-items:center;padding-bottom:0.35rem">
                <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-weight:600">
                    <input type="checkbox" name="available" value="true" checked="@(ViewBag.Available as bool? == true)" /> المتاحين الآن
                </label>
            </div>
            <button class="btn btn-primary" type="submit"><i class="fa-solid fa-filter"></i> تطبيق</button>
        </div>
        <div class="filter-pills" style="margin-top:1rem">
            <span class="muted" style="font-size:0.9rem;margin-inline-end:0.5rem">سريع:</span>
            <a class="pill @(ViewBag.Available as bool? == true ? "is-active" : null)" href="@Url.Action("Browse", new { available = true })">المتاحين الآن</a>
            <a class="pill @((ViewBag.MinRating as decimal? ?? 0) >= 4 ? "is-active" : null)" href="@Url.Action("Browse", new { minRating = 4 })">4+ نجوم</a>
        </div>
    </form>

    <div class="card-grid">
        @foreach (var n in Model)
        {
            <article class="card card--border-hover" style="text-align:center">
                @if (!string.IsNullOrEmpty(n.ProfileImage))
                {
                    <img class="nurse-card__photo" src="@n.ProfileImage" alt="" width="100" height="100" />
                }
                else
                {
                    <div class="nurse-card__photo" style="margin-inline:auto;background:var(--color-bg);display:flex;align-items:center;justify-content:center"><i class="fa-solid fa-user-nurse fa-2x" style="color:var(--color-primary)"></i></div>
                }
                <h3 style="margin:0 0 0.35rem">@n.FullName</h3>
                <p class="muted" style="margin:0">@n.Specialization</p>
                <p class="muted" style="font-size:0.9rem;margin:0.25rem 0">@(n.Neighborhood ?? "")</p>
                <p class="stars-readonly" style="margin:0.5rem 0">@string.Join("", Enumerable.Repeat("★", (int)Math.Round((double)n.AverageRating)))<span class="muted">(@n.TotalReviews)</span></p>
                @if (n.IsAvailable)
                {
                    <span class="badge-tag" style="display:inline-block;margin-bottom:0.5rem">متاح</span>
                }
                else
                {
                    <span class="badge badge-muted" style="margin-bottom:0.5rem">غير متاح</span>
                }
                <p class="muted" style="font-size:0.85rem">@string.Join("، ", n.ServiceNames)</p>
                <a class="btn btn-sm btn-primary" style="margin-top:0.5rem" asp-action="Details" asp-route-id="@n.NurseProfileId">الملف والحجز</a>
            </article>
        }
    </div>
</div>
