@model ClinicServiceEditVM
@{
    Layout = "_DashboardLayout";
    var isEdit = Model.ClinicServiceId.HasValue;
    ViewData["Title"] = isEdit ? "تعديل خدمة" : "إضافة خدمة";
}
@section Sidebar { <partial name="~/Views/Clinic/_Sidebar.cshtml" /> }

<h1 class="page-title">@ViewData["Title"]</h1>

<div class="form-card" style="max-width:520px">
    <form method="post" action="@(isEdit ? Url.Action("Edit", "ClinicServices", new { id = Model.ClinicServiceId })! : Url.Action("Create", "ClinicServices")!)">
        @Html.AntiForgeryToken()
        <div class="form-stack wide" style="max-width:none">
            <div class="field">
                <label asp-for="Name"></label>
                <input asp-for="Name" />
                <span asp-validation-for="Name"></span>
            </div>
            <div class="field">
                <label asp-for="Price"></label>
                <input asp-for="Price" type="number" step="1" min="0" />
                <span asp-validation-for="Price"></span>
            </div>
            <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:0.5rem">
                <button type="submit" class="btn btn-primary">حفظ</button>
                <a class="btn btn-outline" asp-controller="ClinicServices" asp-action="Index">إلغاء</a>
            </div>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
