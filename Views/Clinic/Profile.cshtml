@model ClinicProfileEditVM
@{ Layout = "_DashboardLayout"; ViewData["Title"] = "بيانات العيادة"; }
@section Sidebar { <partial name="_Sidebar" /> }

<h1 class="page-title">بيانات العيادة</h1>
<div class="form-card">
    <form asp-action="Profile" method="post" enctype="multipart/form-data" data-loading>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ClinicId" />
        <div class="form-grid-3" style="max-width:none">
            <div class="field"><label asp-for="ClinicName"></label><input asp-for="ClinicName" /><span asp-validation-for="ClinicName"></span></div>
            <div class="field"><label asp-for="Address"></label><input asp-for="Address" /><span asp-validation-for="Address"></span></div>
            <div class="field"><label asp-for="Neighborhood"></label><input asp-for="Neighborhood" /></div>
            <div class="field"><label asp-for="City"></label><input asp-for="City" /></div>
            <div class="field"><label asp-for="OpeningHours"></label><input asp-for="OpeningHours" /></div>
            <div class="field"><label asp-for="PhoneNumber"></label><input asp-for="PhoneNumber" /></div>
            <div class="field"><label asp-for="Email"></label><input asp-for="Email" /></div>
            <div class="field"><label>خط العرض</label><input asp-for="Latitude" step="any" /></div>
            <div class="field"><label>خط الطول</label><input asp-for="Longitude" step="any" /></div>
            <div class="field"><label asp-for="LogoFile"></label><input asp-for="LogoFile" type="file" accept="image/*" /></div>
            <div class="field"><label asp-for="CoverFile"></label><input asp-for="CoverFile" type="file" accept="image/*" /></div>
            <div class="field"><label asp-for="OwnerProfileImage"></label><input asp-for="OwnerProfileImage" type="file" accept="image/*" /></div>
            <div class="field field-full"><label asp-for="Description"></label><textarea asp-for="Description" rows="3"></textarea></div>
            @if (!string.IsNullOrEmpty(Model.LogoImagePath))
            {
                <p class="muted field-full" style="margin:0">الشعار الحالي: <img src="@Model.LogoImagePath" alt="" style="height:40px;object-fit:cover;border-radius:8px;vertical-align:middle" /></p>
            }
            @if (!string.IsNullOrEmpty(Model.OwnerProfileImagePath))
            {
                <p class="muted field-full" style="margin:0">صورة المالك الحالية: <img src="@Model.OwnerProfileImagePath" alt="" style="height:40px;width:40px;object-fit:cover;border-radius:999px;vertical-align:middle" /></p>
            }
            <div class="field field-full" style="margin-top:0.25rem">
                <button type="submit" class="btn btn-primary">حفظ</button>
            </div>
        </div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
